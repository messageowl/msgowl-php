{
    "name": "messageowl/msgowl-php",
    "description": "PHP SDK for the MessageOwl SMS API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "laravel/pint": "^1.0",
        "illuminate/support": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "MessageOwl\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MessageOwl\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["MessageOwl\\Laravel\\MessageOwlServiceProvider"],
            "aliases": {"MessageOwl": "MessageOwl\\Laravel\\Facades\\MessageOwl"}
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
